@using InventarioWeb.Core.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Inventario</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link href="~/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InventarioWeb.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Inventario Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Inicio
                            </a>
                        </li>

                        <!-- Productos -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-box-seam"></i> Productos
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Productos" asp-action="Index">
                                        <i class="bi bi-list"></i> Todos los Productos
                                    </a>
                                </li>
                                @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Productos" asp-action="Create">
                                            <i class="bi bi-plus-circle"></i> Nuevo Producto
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Categorias" asp-action="Index">
                                        <i class="bi bi-tags"></i> Categorías
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Almacenes (NUEVO) -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-shop"></i> Almacenes
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Almacenes" asp-action="Index">
                                        <i class="bi bi-building"></i> Todos los Almacenes
                                    </a>
                                </li>
                                @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Almacenes" asp-action="Create">
                                            <i class="bi bi-plus-circle"></i> Nuevo Almacén
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>

                        <!-- Movimientos -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-arrow-left-right"></i> Movimientos
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Movimientos" asp-action="Index">
                                        <i class="bi bi-list"></i> Todos los Movimientos
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Movimientos" asp-action="Create" asp-route-tipo="ENTRADA">
                                        <i class="bi bi-box-arrow-in-down"></i> Nueva Entrada
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Movimientos" asp-action="Create" asp-route-tipo="SALIDA">
                                        <i class="bi bi-box-arrow-up"></i> Nueva Salida
                                    </a>
                                </li>
                                @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Movimientos" asp-action="Create" asp-route-tipo="TRASLADO">
                                            <i class="bi bi-arrow-left-right"></i> Nuevo Traslado
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>

                        <!-- Proveedores -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Proveedores" asp-action="Index">
                                <i class="bi bi-truck"></i> Proveedores
                            </a>
                        </li>

                        <!-- Reportes -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reportes" asp-action="Index">
                                <i class="bi bi-file-earmark-bar-graph"></i> Reportes
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Graficos" asp-action="Index">
                                <i class="bi bi-bar-chart"></i> Gráficos
                            </a>
                        </li>

                        <!-- Administración (solo Admin) -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear"></i> Administración
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Usuarios">
                                            <i class="bi bi-people"></i> Usuarios
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="CrearUsuario">
                                            <i class="bi bi-person-plus"></i> Nuevo Usuario
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <!-- Usuario actual -->
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    <i class="bi bi-person-circle"></i>
                                    @User.Identity.Name
                                    <span class="badge bg-info">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <text>Admin</text>
                                        }
                                        else if (User.IsInRole("Gerente"))
                                        {

                                            <text>Gerente</text>
                                        }
                                        else if (User.IsInRole("Operador"))
                                        {

                                            <text>Operador</text>
                                        }
                                        else
                                        {

                                            <text>Consulta</text>
                                        }
                                    </span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-sm mt-1">
                                        <i class="bi bi-box-arrow-right"></i> Salir
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; @DateTime.Now.Year - Sistema de Inventario Web
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
