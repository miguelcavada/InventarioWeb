@model InventarioWeb.Core.DTOs.CategoriaDto
@{
    ViewData["Title"] = "Detalles de Categoría";
}

<div class="row">
    <div class="col-md-10 mx-auto">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0">
                    <i class="bi bi-tag"></i> @Model.Nombre
                </h4>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <dl>
                            <dt>Nombre</dt>
                            <dd><strong>@Model.Nombre</strong></dd>

                            <dt>Descripción</dt>
                            <dd>@(string.IsNullOrEmpty(Model.Descripcion) ? "Sin descripción" : Model.Descripcion)</dd>

                            <dt>Estado</dt>
                            <dd>
                                @if (Model.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h5>Total Productos</h5>
                                <h2>@Model.TotalProductos</h2>
                            </div>
                        </div>
                    </div>
                </div>

                @if (ViewBag.Productos != null)
                {
                    <h5><i class="bi bi-box-seam"></i> Productos en esta categoría</h5>
                    var productos = ViewBag.Productos as IEnumerable<InventarioWeb.Core.DTOs.ProductoDto>;
                    if (productos != null && productos.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Código</th>
                                        <th>Producto</th>
                                        <th class="text-end">Precio Venta</th>
                                        <th class="text-center">Stock Total</th>
                                        <th>Estado</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var producto in productos)
                                    {
                                        <tr>
                                            <td><code>@producto.Codigo</code></td>
                                            <td>@producto.Nombre</td>
                                            <td class="text-end">@producto.PrecioVenta.ToString("C2")</td>
                                            <td class="text-center">
                                                <span class="badge @(producto.StockTotal <= producto.StockMinimoTotal ? "bg-danger" : "bg-success")">
                                                    @producto.StockTotal
                                                </span>
                                            </td>
                                            <td>
                                                @if (producto.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactivo</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-controller="Productos" asp-action="Details" asp-route-id="@producto.Id"
                                                       class="btn btn-info" title="Ver">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                                    {
                                                        <a asp-controller="Productos" asp-action="Edit" asp-route-id="@producto.Id"
                                                           class="btn btn-warning" title="Editar">
                                                            <i class="bi bi-pencil"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No hay productos en esta categoría.
                        </div>
                    }
                }

                <hr />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <div>
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>