@model IEnumerable<InventarioWeb.Core.DTOs.CategoriaDto>
@{
    ViewData["Title"] = "Gestión de Categorías";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tags"></i> Gestión de Categorías</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nueva Categoría
    </a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-folder"></i> @item.Nombre
                    </h5>
                    <p class="card-text text-muted">@item.Descripcion</p>
                    <div class="mb-2">
                        <span class="badge bg-info">
                            @item.TotalProductos productos
                        </span>
                        @if (item.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <div class="btn-group btn-group-sm w-100">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">
                            <i class="bi bi-eye"></i> Ver
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>