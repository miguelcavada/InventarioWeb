@model InventarioWeb.Core.DTOs.AlmacenDto
@{
    ViewData["Title"] = "Eliminar Almacén";
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirmar Eliminación</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-circle"></i>
                    ¿Está seguro que desea eliminar este almacén? Esta acción no se puede deshacer.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">@Model.Nombre</dd>

                    <dt class="col-sm-4">Código</dt>
                    <dd class="col-sm-8"><code>@Model.Codigo</code></dd>

                    <dt class="col-sm-4">Tipo</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.Tipo == "ALMACEN" ? "bg-primary" : "bg-success")">
                            @Model.Tipo
                        </span>
                    </dd>

                    <dt class="col-sm-4">Dirección</dt>
                    <dd class="col-sm-8">@Model.Direccion</dd>

                    <dt class="col-sm-4">Encargado</dt>
                    <dd class="col-sm-8">@Model.Encargado</dd>

                    <dt class="col-sm-4">Productos</dt>
                    <dd class="col-sm-8">@Model.TotalProductos</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Eliminar Permanentemente
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>