@model InventarioWeb.Core.DTOs.AlmacenDto
@{
    ViewData["Title"] = "Detalles del Almacén";
}

<div class="row">
    <div class="col-md-10 mx-auto">
        <div class="card">
            <div class="card-header @(Model.Tipo == "ALMACEN" ? "bg-primary" : "bg-success") text-white">
                <h4 class="mb-0">
                    <i class="bi @(Model.Tipo == "ALMACEN" ? "bi-building" : "bi-shop")"></i>
                    @Model.Nombre
                </h4>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <dl>
                            <dt>Código</dt>
                            <dd><code>@Model.Codigo</code></dd>
                            <dt>Tipo</dt>
                            <dd><span class="badge @(Model.Tipo == "ALMACEN" ? "bg-primary" : "bg-success")">@Model.Tipo</span></dd>
                            <dt>Dirección</dt>
                            <dd>@Model.Direccion</dd>
                            <dt>Descripción</dt>
                            <dd>@(string.IsNullOrEmpty(Model.Descripcion) ? "Sin descripción" : Model.Descripcion)</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl>
                            <dt>Encargado</dt>
                            <dd>@Model.Encargado</dd>
                            <dt>Teléfono</dt>
                            <dd>@Model.Telefono</dd>
                        </dl>
                        <div class="card bg-info text-white">
                            <div class="card-body text-center">
                                <h5>Total Productos</h5>
                                <h2>@Model.TotalProductos</h2>
                            </div>
                        </div>
                        <div class="card bg-success text-white mt-2">
                            <div class="card-body text-center">
                                <h5>Valor Inventario</h5>
                                <h2>@Model.ValorInventario.ToString("C2")</h2>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <div>
                        <a asp-controller="Reportes" asp-action="InventarioAlmacen" asp-route-id="@Model.Id" class="btn btn-info">
                            <i class="bi bi-clipboard-check"></i> Ver Inventario
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>