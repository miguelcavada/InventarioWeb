@model IEnumerable<InventarioWeb.Core.DTOs.StockAlmacenDto>
@{
    ViewData["Title"] = "Inventario Actual";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-clipboard-check"></i> Inventario Actual</h2>
        <h5 class="text-muted">
            <span class="badge @(ViewBag.AlmacenTipo == "ALMACEN" ? "bg-primary" : "bg-success")">
                @ViewBag.AlmacenTipo
            </span>
            @ViewBag.AlmacenNombre
        </h5>
    </div>
    <div>
        <a asp-action="InventarioAlmacenExcel" asp-route-id="@ViewBag.AlmacenId" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <a asp-action="InventarioAlmacenPdf" asp-route-id="@ViewBag.AlmacenId" class="btn btn-danger">
            <i class="bi bi-file-earmark-pdf"></i> PDF
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h5>Total Productos</h5>
                <h2>@Model.Count()</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h5>Total Unidades</h5>
                <h2>@Model.Sum(s => s.StockActual)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning">
            <div class="card-body text-center">
                <h5>Stock Bajo</h5>
                <h2>@Model.Count(s => s.StockActual <= s.StockMinimo && s.StockActual > 0)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h5>Agotados</h5>
                <h2>@Model.Count(s => s.StockActual <= 0)</h2>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Producto</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Mínimo</th>
                        <th class="text-center">Máximo</th>
                        <th>Ubicación</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var estado = item.StockActual <= 0 ? "AGOTADO" :
                        item.StockActual <= item.StockMinimo ? "STOCK BAJO" : "NORMAL";
                        var rowClass = item.StockActual <= 0 ? "table-danger" :
                        item.StockActual <= item.StockMinimo ? "table-warning" : "";

                        <tr class="@rowClass">
                            <td><code>@item.ProductoCodigo</code></td>
                            <td>@item.ProductoNombre</td>
                            <td class="text-center">
                                <span class="badge @(item.StockActual <= item.StockMinimo ? "bg-danger" : "bg-success")">
                                    @item.StockActual
                                </span>
                            </td>
                            <td class="text-center">@item.StockMinimo</td>
                            <td class="text-center">@item.StockMaximo</td>
                            <td>@item.Ubicacion</td>
                            <td>
                                <span class="badge @(estado == "NORMAL" ? "bg-success" : estado == "STOCK BAJO" ? "bg-warning" : "bg-danger")">
                                    @estado
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>