@model IEnumerable<InventarioWeb.Core.DTOs.InventarioDiarioResumenDto>
@{
    ViewData["Title"] = "Inventario Diario";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-clipboard-check"></i> Inventario Diario</h2>
        <h5 class="text-muted">
            @ViewBag.AlmacenNombre - @ViewBag.Fecha.ToString("dd/MM/yyyy")
        </h5>
    </div>
    <div>
        <a asp-action="InventarioDiarioExcel" asp-route-almacenId="@ViewBag.AlmacenId" asp-route-fecha="@ViewBag.Fecha.ToString("yyyy-MM-dd")" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <a asp-action="InventarioDiarioPdf" asp-route-almacenId="@ViewBag.AlmacenId" asp-route-fecha="@ViewBag.Fecha.ToString("yyyy-MM-dd")" class="btn btn-danger">
            <i class="bi bi-file-earmark-pdf"></i> PDF
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<!-- KPIs -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h5>Productos</h5>
                <h2>@Model.Count()</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h5>Entradas del Día</h5>
                <h2>@Model.Sum(m => m.Entradas)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h5>Salidas del Día</h5>
                <h2>@Model.Sum(m => m.Salidas)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h5>Valor Inventario</h5>
                <h2>@Model.Sum(m => m.ValorInventario).ToString("C2")</h2>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Producto</th>
                        <th>Uni</th>
                        <th class="text-center">Exist. Inicial</th>
                        <th class="text-center">Entradas</th>
                        <th class="text-center">Salidas</th>
                        <th class="text-center">Exist. Final</th>
                        <th class="text-end">Precio Minorista</th>
                        <th class="text-end">Precio Mayorista</th>
                        <th class="text-end">Valor</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><code>@item.Codigo</code></td>
                            <td>@item.Producto</td>
                            <td>@item.Unidad</td>
                            <td class="text-center">@item.ExistenciaInicial</td>
                            <td class="text-center">
                                @if (item.Entradas > 0)
                                {
                                    <span class="text-success">+@item.Entradas</span>
                                }
                                else
                                {
                                    <span>0</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.Salidas > 0)
                                {
                                    <span class="text-danger">-@item.Salidas</span>
                                }
                                else
                                {
                                    <span>0</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @(item.ExistenciaFinal <= 0 ? "bg-danger" : "bg-success")">
                                    @item.ExistenciaFinal
                                </span>
                            </td>
                            <td class="text-end">@item.PrecioMinorista.ToString("C2")</td>
                            <td class="text-end">@(item.PrecioMayorista?.ToString("C2") ?? "N/A")</td>
                            <td class="text-end">@item.ValorInventario.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-dark">
                    <tr>
                        <th colspan="3">Totales</th>
                        <th class="text-center">@Model.Sum(m => m.ExistenciaInicial)</th>
                        <th class="text-center">@Model.Sum(m => m.Entradas)</th>
                        <th class="text-center">@Model.Sum(m => m.Salidas)</th>
                        <th class="text-center">@Model.Sum(m => m.ExistenciaFinal)</th>
                        <th colspan="2"></th>
                        <th class="text-end">@Model.Sum(m => m.ValorInventario).ToString("C2")</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>