@model IEnumerable<InventarioWeb.Core.DTOs.ProveedorDto>
@{
    ViewData["Title"] = "Gestión de Proveedores";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-truck"></i> Gestión de Proveedores</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Proveedor
    </a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <!-- Búsqueda -->
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar por nombre, RUC o email..."
                               value="@Context.Request.Query["buscar"]">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
                </div>
            </div>
        </form>

        <!-- Tabla -->
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>RUC</th>
                        <th>Dirección</th>
                        <th>Contacto</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center">
                                <i class="bi bi-inbox display-4 text-muted"></i>
                                <p class="text-muted">No se encontraron proveedores</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <i class="bi bi-building"></i>
                                    <strong>@item.Nombre</strong>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.RUC))
                                    {
                                        <code>@item.RUC</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Direccion))
                                    {
                                        <small><i class="bi bi-geo-alt"></i> @item.Direccion</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Telefono))
                                    {
                                        <div><i class="bi bi-telephone"></i> @item.Telefono</div>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Email))
                                    {
                                        <div>
                                            <a href="mailto:@item.Email">
                                                <i class="bi bi-envelope"></i> @item.Email
                                            </a>
                                        </div>
                                    }
                                    @if (string.IsNullOrEmpty(item.Telefono) && string.IsNullOrEmpty(item.Email))
                                    {
                                        <span class="text-muted">Sin contacto</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-info" title="Detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-warning" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-danger" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <small class="text-muted">
                Total de proveedores: @Model.Count()
            </small>
        </div>
    </div>
</div>