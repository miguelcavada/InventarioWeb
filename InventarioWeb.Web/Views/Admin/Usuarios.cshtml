@model IEnumerable<InventarioWeb.Core.DTOs.UsuarioDto>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Gestión de Usuarios</h2>
    <a asp-action="CrearUsuario" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Nuevo Usuario
    </a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Último Acceso</th>
                        <th>Fecha Registro</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center"
                                         style="width: 35px; height: 35px;">
                                        @item.NombreCompleto.Substring(0, 1).ToUpper()
                                    </div>
                                    <strong>@item.NombreCompleto</strong>
                                </div>
                            </td>
                            <td>
                                <i class="bi bi-envelope"></i> @item.Email
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                {
                                    <i class="bi bi-telephone"></i> 
                                    @item.PhoneNumber
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                <span class="badge @(item.Rol == "Admin" ? "bg-danger" :
                                                                                          item.Rol == "Gerente" ? "bg-warning" :
                                                                                          item.Rol == "Operador" ? "bg-info" : "bg-secondary")">
                                @item.Rol
                            </span>
                        </td>
                        <td>
                            @if (item.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td>
                                @if (item.UltimoAcceso.HasValue)
                                {
                                    <small>@item.UltimoAcceso.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                }
                                else
                                {
                                    <span class="text-muted">Nunca</span>
                                }
                            </td>
                            <td>
                                <small>@item.FechaRegistro.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="EditarUsuario" asp-route-id="@item.Id"
                                       class="btn btn-warning" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="CambiarPassword" asp-route-id="@item.Id"
                                       class="btn btn-info" title="Cambiar Contraseña">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    <form asp-action="CambiarEstado" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="activo" value="@(!item.Activo)" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn @(item.Activo ? "btn-secondary" : "btn-success")"
                                                title="@(item.Activo ? "Desactivar" : "Activar")">
                                            <i class="bi @(item.Activo ? "bi-person-x" : "bi-person-check")"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <div class="row">
                <div class="col-md-3">
                    <div class="card bg-primary text-white">
                        <div class="card-body text-center">
                            <h5>Total Usuarios</h5>
                            <h2>@Model.Count()</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body text-center">
                            <h5>Activos</h5>
                            <h2>@Model.Count(u => u.Activo)</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-danger text-white">
                        <div class="card-body text-center">
                            <h5>Inactivos</h5>
                            <h2>@Model.Count(u => !u.Activo)</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white">
                        <div class="card-body text-center">
                            <h5>Admins</h5>
                            <h2>@Model.Count(u => u.Rol == "Admin")</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>