@model IEnumerable<InventarioWeb.Core.DTOs.HistorialPrecioDto>
@{
    ViewData["Title"] = "Historial de Precios";
    var producto = ViewBag.Producto as InventarioWeb.Core.Entities.Producto;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clock-history"></i> Historial de Cambios de Precios</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Volver a Productos
    </a>
</div>

@if (producto != null)
{
    <div class="alert alert-info mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h5><i class="bi bi-box"></i> @producto.Nombre</h5>
                <small>Código: <code>@producto.Codigo</code></small>
            </div>
            <div class="col-md-4 text-end">
                <a asp-action="CambioPrecio" asp-route-id="@producto.Id" class="btn btn-warning">
                    <i class="bi bi-currency-dollar"></i> Nuevo Cambio de Precio
                </a>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <h4 class="text-muted">Sin historial de cambios</h4>
                <p>Este producto no ha tenido cambios de precio.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha</th>
                            <th>Costo Anterior</th>
                            <th>Costo Nuevo</th>
                            <th>Venta Anterior</th>
                            <th>Venta Nueva</th>
                            <th>Variación Venta</th>
                            <th>Motivo</th>
                            <th>Usuario</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <small>@item.FechaCambio.ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td>
                                    @if (item.PrecioCostoAnterior.HasValue)
                                    {
                                        @item.PrecioCostoAnterior.Value.ToString("C2")
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.PrecioCostoNuevo.HasValue)
                                    {
                                        @item.PrecioCostoNuevo.Value.ToString("C2")
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@item.PrecioVentaAnterior.ToString("C2")</td>
                                <td>@item.PrecioVentaNuevo.ToString("C2")</td>
                                <td>
                                    @{
                                        var variacion = item.PorcentajeVariacion;
                                        var badgeClass = variacion > 0 ? "bg-success" :
                                        variacion < 0 ? "bg-danger" : "bg-secondary";
                                        var icono = variacion > 0 ? "↑" : variacion < 0 ? "↓" : "=";
                                    }
                                    <span class="badge @badgeClass">
                                        @icono @Math.Abs(variacion).ToString("F1")%
                                    </span>
                                </td>
                                <td>
                                    <small>@item.Motivo</small>
                                </td>
                                <td>
                                    <small>@item.UsuarioCambio</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>