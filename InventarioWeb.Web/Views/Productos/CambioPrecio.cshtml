@model InventarioWeb.Core.DTOs.CambioPrecioDto
@{
    ViewData["Title"] = "Cambio de Precios";
    var producto = ViewBag.Producto as InventarioWeb.Core.Entities.Producto;
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0"><i class="bi bi-currency-dollar"></i> Cambio de Precios</h4>
            </div>
            <div class="card-body">
                @if (producto != null)
                {
                    <div class="alert alert-warning">
                        <h5><i class="bi bi-box"></i> @producto.Nombre</h5>
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Precio Costo Actual:</strong>
                                @if (producto.PrecioCosto.HasValue)
                                {
                                    <span class="text-primary">@producto.PrecioCosto.Value.ToString("C2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">No especificado</span>
                                }
                            </div>
                            <div class="col-md-6">
                                <strong>Precio Venta Actual:</strong>
                                <span class="text-success">@producto.PrecioVenta.ToString("C2")</span>
                            </div>
                        </div>
                        <div class="mt-2">
                            <strong>Margen Actual:</strong>
                            @if (producto.MargenGanancia.HasValue)
                            {
                                <span class="badge @(producto.MargenGanancia >= 30 ? "bg-success" : producto.MargenGanancia >= 15 ? "bg-warning" : "bg-danger")">
                                    @producto.MargenGanancia.Value.ToString("F1")%
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Sin costo</span>
                            }
                        </div>
                    </div>
                }

                <form asp-action="CambioPrecio">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="ProductoId" />

                    <div class="mb-3">
                        <label asp-for="PrecioCostoNuevo" class="form-label">
                            Nuevo Precio de Costo <small class="text-muted">(opcional)</small>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PrecioCostoNuevo" class="form-control" type="number" step="0.01"
                                   oninput="calcularMargen()" id="precioCosto" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="PrecioCostoNuevo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PrecioVentaNuevo" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PrecioVentaNuevo" class="form-control" type="number" step="0.01"
                                   oninput="calcularMargen()" id="precioVenta" />
                        </div>
                        <span asp-validation-for="PrecioVentaNuevo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="alert alert-info" id="margenInfo">
                            <strong>Nuevo Margen:</strong> <span id="nuevoMargen">0%</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Motivo" class="form-label"></label>
                        <textarea asp-for="Motivo" class="form-control" rows="3"
                                  placeholder="Ej: Ajuste por inflación, nuevo proveedor, etc."></textarea>
                        <span asp-validation-for="Motivo" class="text-danger"></span>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-info">
                            <i class="bi bi-check-circle"></i> Actualizar Precios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
                function calcularMargen() {
            const costo = parseFloat(document.getElementById('precioCosto').value) || 0;
            const venta = parseFloat(document.getElementById('precioVenta').value) || 0;

            const margenElement = document.getElementById('nuevoMargen');
            const margenInfo = document.getElementById('margenInfo');

            if (costo > 0) {
                const margen = ((venta - costo) / costo * 100);
                margenElement.textContent = margen.toFixed(1) + '%';
                margenInfo.className = 'alert ' + (margen >= 30 ? 'alert-success' :
                                                   margen >= 15 ? 'alert-warning' : 'alert-danger');
            } else {
                margenElement.textContent = 'Sin costo';
                margenInfo.className = 'alert alert-secondary';
            }
        }

        // Calcular al cargar
        calcularMargen();
    </script>
}