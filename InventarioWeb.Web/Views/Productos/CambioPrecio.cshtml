@model InventarioWeb.Core.DTOs.CambioPrecioDto
@{
    ViewData["Title"] = "Cambio de Precios";
    var producto = ViewBag.Producto as InventarioWeb.Core.Entities.Producto;
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0"><i class="bi bi-currency-dollar"></i> Cambio de Precios</h4>
            </div>
            <div class="card-body">
                @if (producto != null)
                {
                    <div class="alert alert-warning">
                        <h5><i class="bi bi-box"></i> @producto.Nombre</h5>
                        <div class="row">
                            <div class="col-md-4">
                                <strong>Costo:</strong> @(producto.PrecioCosto?.ToString("C2") ?? "N/A")
                            </div>
                            <div class="col-md-4">
                                <strong>Minorista:</strong> @producto.PrecioVentaMinorista.ToString("C2")
                            </div>
                            <div class="col-md-4">
                                <strong>Mayorista:</strong> @(producto.PrecioVentaMayorista?.ToString("C2") ?? "N/A")
                            </div>
                        </div>
                    </div>
                }

                <form asp-action="CambioPrecio">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="ProductoId" />

                    <div class="mb-3">
                        <label asp-for="PrecioCostoNuevo" class="form-label">Nuevo Precio de Costo</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PrecioCostoNuevo" class="form-control" type="number" step="0.01" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PrecioVentaMinoristaNuevo" class="form-label">Nuevo Precio Minorista <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PrecioVentaMinoristaNuevo" class="form-control" type="number" step="0.01" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PrecioVentaMayoristaNuevo" class="form-label">Nuevo Precio Mayorista</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PrecioVentaMayoristaNuevo" class="form-control" type="number" step="0.01" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Motivo" class="form-label">Motivo del Cambio</label>
                        <textarea asp-for="Motivo" class="form-control" rows="2" placeholder="Ej: Ajuste por inflación"></textarea>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-info">
                            <i class="bi bi-check-circle"></i> Actualizar Precios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}