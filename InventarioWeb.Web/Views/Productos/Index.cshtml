@model InventarioWeb.Application.Common.PagedResult<InventarioWeb.Core.DTOs.ProductoDto>
@{
    ViewData["Title"] = "Gestión de Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Gestión de Productos</h2>
    <div class="btn-group">
        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Producto
            </a>
        }
        <div class="btn-group">
            <button type="button" class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-download"></i> Exportar
            </button>
            <ul class="dropdown-menu">
                <li>
                    <a class="dropdown-item" asp-controller="Reportes" asp-action="ProductosExcel">
                        <i class="bi bi-file-earmark-excel text-success"></i> Excel
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" asp-controller="Reportes" asp-action="ProductosPdf">
                        <i class="bi bi-file-earmark-pdf text-danger"></i> PDF
                    </a>
                </li>
            </ul>
        </div>
    </div>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <!-- Filtros -->
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar por código o nombre..."
                               value="@Context.Request.Query["buscar"]">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="orden" class="form-select">
                        <option value="nombre">Ordenar por Nombre</option>
                        <option value="codigo">Ordenar por Código</option>
                        <option value="stock">Ordenar por Stock</option>
                        <option value="precio">Ordenar por Precio</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-funnel"></i> Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </div>
        </form>

        <!-- Tabla -->
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Unidad</th>
                        <th>Categoría</th>
                        <th class="text-end">Costo</th>
                        <th class="text-end">Minorista</th>
                        <th class="text-end">Mayorista</th>
                        <th class="text-center">Stock</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data != null && Model.Data.Any())
                    {
                        @foreach (var item in Model.Data)
                        {
                            var stockClass = item.StockTotal <= item.StockMinimoTotal && item.StockTotal > 0 ? "table-danger" : "";
                            <tr class="@stockClass">
                                <td><code>@item.Codigo</code></td>
                                <td>@item.Nombre</td>
                                <td><span class="badge bg-secondary">@item.UnidadMedidaAbreviatura</span></td>
                                <td><span class="badge bg-info">@item.CategoriaNombre</span></td>
                                <td class="text-end">@(item.PrecioCosto?.ToString("C2") ?? "-")</td>
                                <td class="text-end">@item.PrecioVentaMinorista.ToString("C2")</td>
                                <td class="text-end">@(item.PrecioVentaMayorista?.ToString("C2") ?? "-")</td>
                                <td class="text-center">
                                    <span class="badge @(item.StockTotal <= item.StockMinimoTotal ? "bg-danger" : "bg-success")">
                                        @item.StockTotal @item.UnidadMedidaAbreviatura
                                    </span>
                                </td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info" title="Ver"><i class="bi bi-eye"></i></a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning" title="Editar"><i class="bi bi-pencil"></i></a>
                                            <a asp-action="CambioPrecio" asp-route-id="@item.Id" class="btn btn-info" title="Cambiar Precio"><i class="bi bi-currency-dollar"></i></a>
                                        }
                                        <a asp-action="HistorialPrecios" asp-route-id="@item.Id" class="btn btn-outline-info" title="Historial"><i class="bi bi-clock-history"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger" title="Eliminar"><i class="bi bi-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center py-4">
                                <i class="bi bi-inbox display-4 text-muted"></i>
                                <p class="text-muted">No se encontraron productos</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Paginación">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-buscar="@Context.Request.Query["buscar"]"
                           asp-route-orden="@Context.Request.Query["orden"]"
                           asp-route-pagina="@(Model.Page - 1)">
                            <i class="bi bi-chevron-left"></i> Anterior
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-buscar="@Context.Request.Query["buscar"]"
                               asp-route-orden="@Context.Request.Query["orden"]"
                               asp-route-pagina="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-buscar="@Context.Request.Query["buscar"]"
                           asp-route-orden="@Context.Request.Query["orden"]"
                           asp-route-pagina="@(Model.Page + 1)">
                            Siguiente <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }

        <!-- Resumen -->
        <div class="row mt-3">
            <div class="col-md-4">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h5>Total Productos</h5>
                        <h2>@Model.TotalCount</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h5>Página</h5>
                        <h2>@Model.Page de @Model.TotalPages</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-secondary text-white">
                    <div class="card-body text-center">
                        <h5>Por página</h5>
                        <h2>@Model.Data.Count()</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('select[name="orden"]').val('@Context.Request.Query["orden"]');
        });
    </script>
}