@model IEnumerable<InventarioWeb.Core.DTOs.MovimientoDto>
@{
    ViewData["Title"] = "Historial de Movimientos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-arrow-left-right"></i> Historial de Movimientos</h2>
    <div>
        <a asp-action="Create" asp-route-tipo="ENTRADA" class="btn btn-success">
            <i class="bi bi-box-arrow-in-down"></i> Nueva Entrada
        </a>
        <a asp-action="Create" asp-route-tipo="SALIDA" class="btn btn-danger">
            <i class="bi bi-box-arrow-up"></i> Nueva Salida
        </a>
        <a asp-action="Create" asp-route-tipo="TRASLADO" class="btn btn-info">
            <i class="bi bi-arrow-left-right"></i> Nuevo Traslado
        </a>
    </div>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-3">
                    <select name="tipo" class="form-select">
                        <option value="TODOS">Todos los tipos</option>
                        <option value="ENTRADA">Entradas</option>
                        <option value="SALIDA">Salidas</option>
                        <option value="TRASLADO">Traslados</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" name="desde" class="form-control" placeholder="Desde" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="hasta" class="form-control" placeholder="Hasta" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-funnel"></i> Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Documento</th>
                        <th>Tipo</th>
                        <th>Origen</th>
                        <th>Destino</th>
                        <th>Fecha</th>
                        <th>Observación</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><code>@item.NumeroDocumento</code></td>
                            <td>
                                @switch (item.Tipo)
                                {
                                    case "ENTRADA":
                                        <span class="badge bg-success">
                                            <i class="bi bi-box-arrow-in-down"></i> Entrada
                                        </span>
                                        break;
                                    case "SALIDA":
                                        <span class="badge bg-danger">
                                            <i class="bi bi-box-arrow-up"></i> Salida
                                        </span>
                                        break;
                                    case "TRASLADO":
                                        <span class="badge bg-info">
                                            <i class="bi bi-arrow-left-right"></i> Traslado
                                        </span>
                                        break;
                                }
                            </td>
                            <td><small>@item.AlmacenOrigenNombre</small></td>
                            <td><small>@item.AlmacenDestinoNombre</small></td>
                            <td>@item.FechaMovimiento.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Observacion</td>
                            <td class="text-end">
                                <strong>@item.Total.ToString("C2")</strong>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>