@model InventarioWeb.Core.DTOs.ConsignacionDto
@{
    ViewData["Title"] = $"Consignación #{Model.NumeroConsignacion}";
}

<div class="row">
    <div class="col-md-10 mx-auto">
        <div class="card">
            <div class="card-header @(Model.Estado == "COMPLETADA" ? "bg-success" : Model.Estado == "PENDIENTE" ? "bg-warning" : "bg-info") text-white">
                <h4 class="mb-0">
                    <i class="bi bi-box-arrow-right"></i>
                    Consignación #@Model.NumeroConsignacion
                </h4>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <dl>
                            <dt>Estado</dt>
                            <dd>
                                @switch (Model.Estado)
                                {
                                    case "PENDIENTE":
                                        <span class="badge bg-warning">Pendiente</span>
                                        break;
                                    case "PARCIAL":
                                        <span class="badge bg-info">Parcial</span>
                                        break;
                                    case "COMPLETADA":
                                        <span class="badge bg-success">Completada</span>
                                        break;
                                    case "CANCELADA":
                                        <span class="badge bg-danger">Cancelada</span>
                                        break;
                                }
                            </dd>
                            <dt>Fecha Entrega</dt>
                            <dd>@Model.FechaEntrega.ToString("dd/MM/yyyy")</dd>
                            @if (Model.FechaDevolucion.HasValue)
                            {
                                <dt>Fecha Devolución</dt>
                                <dd>@Model.FechaDevolucion.Value.ToString("dd/MM/yyyy")</dd>
                            }
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl>
                            <dt>Vendedor</dt>
                            <dd><strong>@Model.VendedorNombre</strong></dd>
                            <dt>Contacto</dt>
                            <dd>@Model.VendedorContacto</dd>
                            <dt>Teléfono</dt>
                            <dd>@Model.VendedorTelefono</dd>
                            <dt>Almacén Origen</dt>
                            <dd>@Model.AlmacenOrigenNombre</dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                    <div class="alert alert-info">
                        <strong>Observaciones:</strong> @Model.Observaciones
                    </div>
                }

                <!-- Resumen -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h5>Entregados</h5>
                                <h2>@Model.TotalProductos</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center">
                                <h5>Vendidos</h5>
                                <h2>@Model.TotalVendidos</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-info text-white">
                            <div class="card-body text-center">
                                <h5>Devueltos</h5>
                                <h2>@Model.TotalDevueltos</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning">
                            <div class="card-body text-center">
                                <h5>Pendientes</h5>
                                <h2>@(Model.TotalProductos - Model.TotalVendidos - Model.TotalDevueltos)</h2>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabla de detalles -->
                <h5><i class="bi bi-box-seam"></i> Productos</h5>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Código</th>
                                <th>Producto</th>
                                <th class="text-center">Entregados</th>
                                <th class="text-center">Vendidos</th>
                                <th class="text-center">Devueltos</th>
                                <th class="text-center">Pendientes</th>
                                <th class="text-end">Precio</th>
                                <th class="text-end">Total Vendido</th>
                                @if (Model.Estado != "COMPLETADA" && Model.Estado != "CANCELADA")
                                {
                                    <th class="text-center">Acciones</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Detalles)
                            {
                                var pendiente = detalle.CantidadEntregada - detalle.CantidadVendida - detalle.CantidadDevuelta;
                                <tr>
                                    <td><code>@detalle.ProductoCodigo</code></td>
                                    <td>@detalle.ProductoNombre</td>
                                    <td class="text-center">@detalle.CantidadEntregada</td>
                                    <td class="text-center">@detalle.CantidadVendida</td>
                                    <td class="text-center">@detalle.CantidadDevuelta</td>
                                    <td class="text-center">
                                        <span class="badge @(pendiente > 0 ? "bg-warning" : "bg-success")">
                                            @pendiente
                                        </span>
                                    </td>
                                    <td class="text-end">@detalle.PrecioUnitario.ToString("C2")</td>
                                    <td class="text-end">@detalle.SubtotalVendido.ToString("C2")</td>
                                    @if (Model.Estado != "COMPLETADA" && Model.Estado != "CANCELADA" && pendiente > 0)
                                    {
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button type="button" class="btn btn-success btn-registrar-venta"
                                                        data-id="@detalle.Id"
                                                        data-producto="@detalle.ProductoNombre"
                                                        data-pendiente="@pendiente">
                                                    <i class="bi bi-cart-check"></i> Venta
                                                </button>
                                                <button type="button" class="btn btn-info btn-registrar-devolucion"
                                                        data-id="@detalle.Id"
                                                        data-producto="@detalle.ProductoNombre"
                                                        data-pendiente="@pendiente">
                                                    <i class="bi bi-box-arrow-in-left"></i> Devolución
                                                </button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-dark">
                                <th colspan="2">Totales</th>
                                <th class="text-center">@Model.TotalProductos</th>
                                <th class="text-center">@Model.TotalVendidos</th>
                                <th class="text-center">@Model.TotalDevueltos</th>
                                <th class="text-center">@(Model.TotalProductos - Model.TotalVendidos - Model.TotalDevueltos)</th>
                                <th></th>
                                <th class="text-end">@Model.TotalVendidoValor.ToString("C2")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <hr />
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Modal Registrar Venta -->
<div class="modal fade" id="modalVenta" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="RegistrarVenta" method="post">
                <input type="hidden" name="ConsignacionDetalleId" id="ventaDetalleId" />
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-cart-check"></i> Registrar Venta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Producto: <strong id="ventaProducto"></strong></p>
                    <p>Pendiente: <strong id="ventaPendiente"></strong> unidades</p>
                    <div class="mb-3">
                        <label class="form-label">Cantidad Vendida</label>
                        <input name="CantidadVendida" class="form-control" type="number" min="1" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">Registrar Venta</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Registrar Devolución -->
<div class="modal fade" id="modalDevolucion" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="RegistrarDevolucion" method="post">
                <input type="hidden" name="ConsignacionDetalleId" id="devolucionDetalleId" />
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="bi bi-box-arrow-in-left"></i> Registrar Devolución</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Producto: <strong id="devolucionProducto"></strong></p>
                    <p>Pendiente: <strong id="devolucionPendiente"></strong> unidades</p>
                    <div class="mb-3">
                        <label class="form-label">Cantidad Devuelta</label>
                        <input name="CantidadDevuelta" class="form-control" type="number" min="1" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-info">Registrar Devolución</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('.btn-registrar-venta').click(function() {
            const id = $(this).data('id');
            const producto = $(this).data('producto');
            const pendiente = $(this).data('pendiente');

            $('#ventaDetalleId').val(id);
            $('#ventaProducto').text(producto);
            $('#ventaPendiente').text(pendiente);
            $('#modalVenta').modal('show');
        });

        $('.btn-registrar-devolucion').click(function() {
            const id = $(this).data('id');
            const producto = $(this).data('producto');
            const pendiente = $(this).data('pendiente');

            $('#devolucionDetalleId').val(id);
            $('#devolucionProducto').text(producto);
            $('#devolucionPendiente').text(pendiente);
            $('#modalDevolucion').modal('show');
        });
    </script>
}