@model InventarioWeb.Core.DTOs.ConsignacionDto
@{
    ViewData["Title"] = "Nueva Consignación";
}

<div class="row">
    <div class="col-md-10 mx-auto">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Nueva Consignación</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" id="formConsignacion">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="NumeroConsignacion" class="form-label"></label>
                            <input asp-for="NumeroConsignacion" class="form-control" placeholder="CONS-001" required />
                            <span asp-validation-for="NumeroConsignacion" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FechaEntrega" class="form-label"></label>
                            <input asp-for="FechaEntrega" class="form-control" type="date" required />
                            <span asp-validation-for="FechaEntrega" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="AlmacenOrigenId" class="form-label">Almacén Origen</label>
                            <select asp-for="AlmacenOrigenId" class="form-select" asp-items="ViewBag.Almacenes" required>
                                <option value="">-- Seleccione --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="VendedorNombre" class="form-label"></label>
                            <input asp-for="VendedorNombre" class="form-control" placeholder="Nombre del vendedor" required />
                            <span asp-validation-for="VendedorNombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="VendedorContacto" class="form-label">Contacto</label>
                            <input asp-for="VendedorContacto" class="form-control" placeholder="Email o dirección" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="VendedorTelefono" class="form-label">Teléfono</label>
                            <input asp-for="VendedorTelefono" class="form-control" placeholder="Teléfono" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Observaciones" class="form-label"></label>
                        <textarea asp-for="Observaciones" class="form-control" rows="2" placeholder="Observaciones..."></textarea>
                    </div>

                    <hr />
                    <h5>Productos a Consignar</h5>
                    
                    <div id="detallesContainer">
                        <div class="detalle-item mb-3 border p-3 rounded">
                            <div class="row g-2">
                                <div class="col-md-5">
                                    <label class="form-label">Producto</label>
                                    <select name="Detalles[0].ProductoId" class="form-select producto-select" required>
                                        <option value="">-- Seleccione --</option>
                                        @foreach (var item in ViewBag.Productos)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Cantidad</label>
                                    <input name="Detalles[0].CantidadEntregada" class="form-control" type="number" min="1" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Precio Unitario</label>
                                    <input name="Detalles[0].PrecioUnitario" class="form-control" type="number" step="0.01" required />
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label">&nbsp;</label>
                                    <button type="button" class="btn btn-danger btn-remove-detalle d-none">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="button" id="btnAgregarDetalle" class="btn btn-outline-secondary mb-3">
                        <i class="bi bi-plus-circle"></i> Agregar Producto
                    </button>

                    <hr />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Crear Consignación
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let detalleIndex = 1;

        function toggleRemoveButtons() {
            const items = $('.detalle-item');
            items.find('.btn-remove-detalle').toggleClass('d-none', items.length === 1);
        }

        $('#btnAgregarDetalle').click(function() {
            const template = `
                <div class="detalle-item mb-3 border p-3 rounded">
                    <div class="row g-2">
                        <div class="col-md-5">
                            <select name="Detalles[${detalleIndex}].ProductoId" class="form-select" required>
                                <option value="">-- Seleccione --</option>
                                @foreach (var item in ViewBag.Productos)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <input name="Detalles[${detalleIndex}].CantidadEntregada" class="form-control" type="number" min="1" required />
                        </div>
                        <div class="col-md-3">
                            <input name="Detalles[${detalleIndex}].PrecioUnitario" class="form-control" type="number" step="0.01" required />
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-danger btn-remove-detalle">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>`;
            
            $('#detallesContainer').append(template);
            detalleIndex++;
            toggleRemoveButtons();
        });

        $(document).on('click', '.btn-remove-detalle', function() {
            $(this).closest('.detalle-item').remove();
            toggleRemoveButtons();
        });
    </script>
}