@model IEnumerable<InventarioWeb.Core.DTOs.ConsignacionDto>
@{
    ViewData["Title"] = "Consignaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-arrow-right"></i> Consignaciones</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Gerente") || User.IsInRole("Operador"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Consignación
        </a>
    }
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>N° Consignación</th>
                        <th>Fecha Entrega</th>
                        <th>Vendedor</th>
                        <th>Almacén</th>
                        <th>Entregados</th>
                        <th>Vendidos</th>
                        <th>Devueltos</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><code>@item.NumeroConsignacion</code></td>
                            <td>@item.FechaEntrega.ToString("dd/MM/yyyy")</td>
                            <td>
                                <strong>@item.VendedorNombre</strong>
                                @if (!string.IsNullOrEmpty(item.VendedorTelefono))
                                {
                                    <br />
                            
                                    <small><i class="bi bi-telephone"></i> @item.VendedorTelefono</small>
                                }
                            </td>
                            <td>@item.AlmacenOrigenNombre</td>
                            <td class="text-center">@item.TotalProductos</td>
                            <td class="text-center">@item.TotalVendidos</td>
                            <td class="text-center">@item.TotalDevueltos</td>
                            <td>
                                @switch (item.Estado)
                                {
                                    case "PENDIENTE":
                                        <span class="badge bg-warning">Pendiente</span>
                                        break;
                                    case "PARCIAL":
                                        <span class="badge bg-info">Parcial</span>
                                        break;
                                    case "COMPLETADA":
                                        <span class="badge bg-success">Completada</span>
                                        break;
                                    case "CANCELADA":
                                        <span class="badge bg-danger">Cancelada</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>